@{
    ViewData["Title"] = "Makale Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h4 class="mb-0">Makale Yönetimi</h4>
    </div>
    <div class="card-body">
        @Html.AntiForgeryToken()

        <table id="submissionTable" class="table table-striped table-bordered align-middle w-100">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Başlık</th>
                    <th>Yazar</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th style="width:160px;">İşlemler</th>
                </tr>
            </thead>
        </table>
    </div>

@section Scripts {
    <script>
        function getStatusBadge(status) {
            let badgeClass = "bg-secondary";

            switch (status) {
                case "Submitted":
                    badgeClass = "bg-primary";
                    break;
                case "InReview":
                    badgeClass = "bg-warning text-dark";
                    break;
                case "RevisionRequired":
                    badgeClass = "bg-info text-dark";
                    break;
                case "Accepted":
                    badgeClass = "bg-success";
                    break;
                case "Rejected":
                    badgeClass = "bg-danger";
                    break;
                case "Draft":
                    badgeClass = "bg-secondary";
                    break;
            }

            return `<span class="badge ${badgeClass}">${status}</span>`;
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleString('tr-TR');
        }

        function showAppToast(message) {
            const toastBody = document.getElementById('liveToastBody');
            const toastEl = document.getElementById('liveToast');

            if (toastBody && toastEl) {
                toastBody.textContent = message;
                const toast = new bootstrap.Toast(toastEl);
                toast.show();
            } else {
                alert(message);
            }
        }

                    $(document).ready(function () {
        if ($.fn.DataTable.isDataTable('#submissionTable')) {
            $('#submissionTable').DataTable().destroy();
        }
                        $(document).on('click', '.btn-delete-submission', function () {
                    const id = $(this).data('id');

                    if (!confirm('Bu makale silinsin mi? Bu işlem geri alınamaz.')) {
                        return;
                    }

                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    $.ajax({
                        url: '/Submission/Delete',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: token
                        },
                        success: function () {
                            $('#submissionTable').DataTable().ajax.reload(null, false);
                            showAppToast('Makale başarıyla silindi.');
                        },
                        error: function () {
                            alert('Makale silinirken hata oluştu.');
                        }
                    });
                });
        $('#submissionTable').DataTable({
            info: false,
                ajax: {
                    url: '/Admin/SubmissionManagement/GetSubmissions',
                    type: 'GET'
                },
                columns: [
                    { data: 'id' },
                    { data: 'title' },
                    { data: 'author' },
                    {
                        data: 'status',
                        render: function (data) {
                            return getStatusBadge(data);
                        }
                    },
                    {
                        data: 'createdAt',
                        render: function (data) {
                            return formatDate(data);
                        }
                    },
                            {
            data: 'id',
            orderable: false,
            searchable: false,
                            render: function (data) {
                    return `
                        <div class="d-flex flex-column gap-2">
                            <a href="/Submission/Detail/${data}" class="btn btn-sm btn-info">Detay</a>
                            <a href="/Submission/UpdateStatus/${data}" class="btn btn-sm btn-warning">Durum Güncelle</a>
                            <button type="button" class="btn btn-sm btn-danger btn-delete-submission" data-id="${data}">
                                Sil
                            </button>
                        </div>
                    `;
                }
        }
                ],
                order: [[0, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.8/i18n/tr.json'
                }
            });
        });
    </script>
}