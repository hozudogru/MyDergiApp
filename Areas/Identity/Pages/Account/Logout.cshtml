@page
@model LogoutModel

@{
    ViewData["Title"] = "Çıkış Yap";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm text-center">
            <div class="card-header">
                <h4>Çıkış Yapıldı</h4>
            </div>

            <div class="card-body">
                <p class="mb-3">
                    Başarıyla çıkış yaptınız.
                </p>

                <a asp-page="/Account/Login" class="btn btn-primary">
                    Tekrar Giriş Yap
                </a>
            </div>
        </div>
    </div>
</div>