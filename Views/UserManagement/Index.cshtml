@model List<MyDergiApp.ViewModels.UserListViewModel>

@{
    ViewData["Title"] = "Kullanıcılar";
}

<div class="container-fluid mt-3">
    <h2>Kullanıcılar</h2>

    <table class="table table-bordered table-striped mt-3">
        <thead>
            <tr>
                <th>Ad Soyad</th>
                <th>Email</th>
                <th>Durum</th>
                <th>Rol</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </td>
                    <td>@user.RoleName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-primary btn-sm">
                            Düzenle
                        </a>

                        <a asp-action="EditRoles" asp-route-id="@user.Id" class="btn btn-warning btn-sm">
                            Roller
                        </a>

                        <form asp-action="ToggleActive" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />

                            @if (user.IsActive)
                            {
                                <button class="btn btn-danger btn-sm">Pasif Yap</button>
                            }
                            else
                            {
                                <button class="btn btn-success btn-sm">Aktif Yap</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>