@model IEnumerable<MyDergiApp.ViewModels.UserListViewModel>

@using System.Security.Claims@{
    ViewData["Title"] = "Kullanıcılar";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Kullanıcılar</h2>
        @if (User.IsInRole("Admin"))
        {
            <a href="/UserManagement/TestMail" class="btn btn-warning mb-3">
                📧 Mail Test
            </a>
        }
        @if (User.IsInRole("Admin"))
        {
            <div class="mb-3 d-flex justify-content-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-person-plus"></i> Yeni Kullanıcı
                </a>
            </div>
        }
        <p class="text-muted mb-0">Sistemde kayıtlı kullanıcıları yönetin.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-2">Toplam Kullanıcı</div>
                <div class="fs-2 fw-bold">@Model.Count()</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-2">Aktif</div>
                <div class="fs-2 fw-bold text-success">@Model.Count(x => x.IsActive)</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-2">Pasif</div>
                <div class="fs-2 fw-bold text-danger">@Model.Count(x => !x.IsActive)</div>
            </div>
        </div>
    </div>
</div>


<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table id="usersTable" class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Email</th>
                        <th>Durum</th>
                        <th>Rol</th>
                        <th>Oluşturulma</th>
                        <th style="width: 260px;">İşlemler</th>
                    </tr>
                </thead>
               
                <tbody>
                   
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>

                            <td>
                                <span class="badge status-badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                    @(item.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>

                            <td>
                                <div class="d-flex flex-nowrap gap-2">
                                    @foreach (var role in item.Roles)
                                    {
                                        var roleClass = role.Trim().ToLower() switch
                                        {
                                            "admin" => "role-badge role-admin",
                                            "editor" => "role-badge role-editor",
                                            "reviewer" => "role-badge role-reviewer",
                                            "author" => "role-badge role-author",
                                            "reader" => "role-badge role-reader",
                                            _ => "role-badge role-author"
                                        };

                                        <span class="@roleClass">@role</span>
                                    }
                                </div>
                               </td>
                         

                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>

                            <td class="align-middle">
                                <div class="action-buttons">
                                    <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i> Düzenle
                                    </a>

                                    <a asp-action="EditRoles"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-secondary">
                                        <i class="bi bi-people"></i> Roller
                                    </a>

                                    @if (item.Id == currentUserId)
                                    {
                                        <button type="button"
                                                class="btn btn-sm @(item.IsActive ? "btn-danger" : "btn-success")"
                                                disabled
                                                title="Kendi hesabınızı pasif yapamazsınız">
                                            <i class="bi @(item.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                            @(item.IsActive ? "Pasif Yap" : "Aktif Yap")
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm @(item.IsActive ? "btn-danger" : "btn-success") toggle-status"
                                                data-id="@item.Id">
                                            <i class="bi @(item.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                            @(item.IsActive ? "Pasif Yap" : "Aktif Yap")
                                        </button>
                                    }
                                   
                                    @if (User.IsInRole("Admin") && !item.Roles.Contains("Admin"))
                                    {
                                        if (!item.HasSubmissions)
                                        {
                                            <form asp-action="Delete" method="post" class="d-inline"
                                                  onsubmit="return confirm('Bu kullanıcı silinsin mi?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Sil
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Makalesi var</span>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
                    $('#usersTable').DataTable({
            retrieve: true,
            info: false,
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.8/i18n/tr.json'
            },
            pageLength: 10,
            lengthMenu: [5, 10, 25, 50],

            order: [[4, 'desc']],

            columnDefs: [
                { orderable: false, targets: 5 }
            ],

            responsive: true,
            autoWidth: false
        });
        });
    </script>
}