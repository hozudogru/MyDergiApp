@model MyDergiApp.ViewModels.Users.EditUserRolesViewModel

@{
    ViewData["Title"] = "Kullanıcı Rolleri";
}

<div class="container mt-4">
    <h2>Rol Yönetimi</h2>

    <div class="mb-3">
        <strong>@Model.FullName</strong> - @Model.Email
    </div>

    <form asp-action="EditRoles" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="UserId" />

        @for (int i = 0; i < Model.Roles.Count; i++)
        {
            <div class="form-check">
                <input type="hidden" asp-for="Roles[i].RoleName" />

                <input asp-for="Roles[i].Selected" class="form-check-input" />
                <label class="form-check-label">
                    @Model.Roles[i].RoleName
                </label>
            </div>
        }

        <button type="submit" class="btn btn-primary mt-3">Kaydet</button>
        <a asp-action="Index" class="btn btn-secondary mt-3">Geri</a>
    </form>
</div>