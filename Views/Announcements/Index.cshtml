@model IEnumerable<MyDergiApp.Models.Announcement>
@{
    ViewData["Title"] = "Duyurular";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Duyurular</h2>
    <a asp-action="Create" class="btn btn-primary">Yeni Duyuru</a>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Tarih</th>
                    <th>Aktif</th>
                    <th>Popup</th>
                    <th style="width:260px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td>
                            @if (item.ShowAsPopup)
                            {
                                <span class="badge bg-warning text-dark">Popup</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">Hayır</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a>

                                <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        @(item.IsActive ? "Pasif Yap" : "Aktif Yap")
                                    </button>
                                </form>

                                <form asp-action="TogglePopup" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        @(item.ShowAsPopup ? "Popup Kaldır" : "Popup Yap")
                                    </button>
                                </form>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>