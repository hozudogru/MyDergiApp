@using Microsoft.AspNetCore.Identity
@using MyDergiApp.Entities
@inject SignInManager<AppUser> SignInManager

<div class="userbar-wrap">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="userbar-name">Merhaba, @User.Identity?.Name</span>

        <form asp-area="Identity"
              asp-page="/Account/Logout"
              method="post"
              class="d-inline">
            <button type="submit" class="btn btn-sm btn-outline-dark">Çıkış</button>
        </form>
    }
    else
    {
        <a class="btn btn-sm btn-outline-dark me-2" asp-area="Identity" asp-page="/Account/Login">Giriş</a>
        <a class="btn btn-sm btn-dark" asp-area="Identity" asp-page="/Account/Register">Kayıt</a>
    }
</div>