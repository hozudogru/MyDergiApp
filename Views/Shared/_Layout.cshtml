<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyDergiApp</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <a asp-controller="Home" asp-action="Index">MyDergiApp</a>
                <span>Journal Admin</span>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index" class="sidebar-link">Ana Sayfa</a>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="sidebar-link">Dashboard</a>
                        <a asp-controller="Journal" asp-action="Index" class="sidebar-link">Dergiler</a>
                        <a asp-controller="Submission" asp-action="AdminList" class="sidebar-link">Tüm Makaleler</a>
                        
                        <a asp-controller="UserManagement" asp-action="Index" class="sidebar-link">Kullanıcılar</a>
                    }

                    @if (User.IsInRole("Author"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Submission" asp-action="Index">
                                📄 Makalelerim
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Submission" asp-action="Create">
                                ➕ Yeni Makale
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Submission" asp-action="AdminList">
                                🗂️ Tüm Makaleler
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Editor"))
                    {
                        <a asp-controller="Submission" asp-action="AdminList" class="sidebar-link">Başvurular</a>
                    }
                    @if (User.IsInRole("Reviewer"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Submission" asp-action="MyReviews">
                                Değerlendirmelerim
                            </a>
                        </li>
                    }
                }
            </nav>
        </aside>

        <div class="admin-main">
            <header class="admin-header">
                <h1 class="admin-title">@ViewData["Title"]</h1>
                <div class="admin-userbar">
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>