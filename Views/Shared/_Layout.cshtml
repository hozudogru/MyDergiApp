<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyDergiApp</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/frontpage.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        string ActiveClass(string controller, string? action = null)
        {
            var controllerMatch = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
            var actionMatch = action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
            return controllerMatch && actionMatch ? "active" : "";
        }
    }

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="d-flex min-vh-100">
            <aside class="bg-dark text-white p-3" style="width:260px;">
                <h2 class="fw-bold mb-1">MyDergiApp</h2>
                <div class="text-white-50 mb-4">Journal Management Panel</div>

                <nav class="nav flex-column">
                    <a asp-controller="Home" asp-action="Index"
                           class="nav-link text-white rounded mb-1 @ActiveClass("Home", "Index")">
                        Ana Sayfa
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="text-uppercase small text-white-50 mt-3 mb-2">Yönetim</div>

                        <a asp-controller="Admin" asp-action="Index"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Admin", "Index")">
                            Dashboard
                        </a>

                        <a asp-controller="Journal" asp-action="Index"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Journal", "Index")">
                            Dergiler
                        </a>

                        <a asp-area="Admin" asp-controller="SubmissionManagement" asp-action="Index"
                               class="nav-link text-white rounded mb-1 @ActiveClass("SubmissionManagement", "Index")">
                            Tüm Makaleler
                        </a>

                        <a href="/UserManagement"
                               class="nav-link text-white rounded mb-1 @ActiveClass("UserManagement", "Index")">
                            Kullanıcılar
                        </a>
                        <a asp-controller="Announcements" asp-action="Index"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Announcements", "Index")">
                            Duyurular
                        </a>
                    }
                   
                    @if (User.IsInRole("Editor"))
                    {
                        <div class="text-uppercase small text-white-50 mt-3 mb-2">Editör</div>

                        <a asp-controller="Submission" asp-action="AdminList"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Submission", "AdminList")">
                            Tüm Makaleler
                        </a>
                    }

                    @if (User.IsInRole("Reviewer"))
                    {
                        <div class="text-uppercase small text-white-50 mt-3 mb-2">Hakem</div>

                        <a asp-controller="Reviewer" asp-action="Index"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Reviewer", "Index")">
                            Değerlendirmelerim
                        </a>
                    }

                    @if (User.IsInRole("Author"))
                    {
                        <div class="text-uppercase small text-white-50 mt-3 mb-2">Yazar İşlemleri</div>

                        <a asp-controller="Submission" asp-action="Index"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Submission", "Index")">
                            Makalelerim
                        </a>

                        <a asp-controller="Submission" asp-action="Create"
                               class="nav-link text-white rounded mb-1 @ActiveClass("Submission", "Create")">
                            Yeni Makale
                        </a>
                    }
                </nav>
            </aside>

            <div class="flex-grow-1 d-flex flex-column">
                <header class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">@ViewData["Title"]</h4>

                    <div class="d-flex align-items-center gap-3">
                        <span>Merhaba, @User.Identity?.Name</span>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Çıkış</button>
                        </form>
                    </div>
                </header>

                <main class="flex-grow-1 p-4 bg-light">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column min-vh-100">
            <header class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
                <h4 class="mb-0">@ViewData["Title"]</h4>

                <div class="d-flex align-items-center gap-2">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-sm">Giriş</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm">Kayıt Ol</a>
                </div>
            </header>

            <main class="flex-grow-1 p-4 bg-light">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                @RenderBody()
            </main>
        </div>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080">
        <div id="liveToast" class="toast align-items-center text-bg-dark border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="liveToastBody">
                    İşlem başarılı.
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Kapat"></button>
            </div>
        </div>
    </div>
</body>
</html>