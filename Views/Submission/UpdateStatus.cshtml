@model MyDergiApp.ViewModels.Submissions.SubmissionStatusUpdateViewModel

@{
    ViewData["Title"] = "Durum Güncelle";
}

<div class="card">
    <div class="card-header">
        <h4 class="mb-0">Makale Durumu Güncelle</h4>
    </div>
    <div class="card-body">

        <form asp-action="UpdateStatus" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="SubmissionId" />

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<MyDergiApp.Models.SubmissionStatus>()">
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NoteToEditor" class="form-label">Editör Notu</label>
                <textarea asp-for="NoteToEditor" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="DecisionNote" class="form-label">Karar Notu</label>
                <textarea asp-for="DecisionNote" class="form-control" rows="4"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a asp-action="AdminList" class="btn btn-secondary">İptal</a>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}