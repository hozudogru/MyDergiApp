@model IEnumerable<MyDergiApp.Entities.Journal>

@{
    ViewData["Title"] = "Dergiler";
}

<h1>Dergiler</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Dergi Ekle</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Dergi Adı</th>
            <th>ISSN</th>
            <th>Açıklama</th>
            <th>Aktif</th>
            <th style="width:220px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Issn</td>
            <td>@item.Description</td>
            <td>@(item.IsActive ? "Evet" : "Hayır")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detay</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
            </td>
                <th>İşlem</th>
            <td>
                    <a asp-action="EditRoles" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        Roller
                    </a>
            </td>
        </tr>
    }
    </tbody>
</table>
